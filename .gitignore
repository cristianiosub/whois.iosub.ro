# ----------------------------------------

# Variabile de mediu
.env
.env.*
!.env.example
!.env.sample

# Configurații aplicație
config.php
config.local.php
settings.php
database.php
db.php
connection.php
*.local.php
*.secret.php

# Chei API & certificate
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
*.jks
*.keystore

# Fișiere cu credențiale explicite
credentials.php
credentials.json
secrets.php
secrets.json
secrets.yml
secrets.yaml
auth.json
service-account*.json
*.token
*.tokens

